# 複製為 .env 後填入實際金鑰
# Anthropic API(必填)— https://platform.claude.com
ANTHROPIC_API_KEY=

# Apollo.io(L1 主力名單來源;免費 tier 可先驗證流程)
APOLLO_API_KEY=

# Hunter.io(L2 email 驗證;500 筆內有免費額度)
HUNTER_API_KEY=

# Google Maps Places API(L1 掃描目標城市咖啡店/廚具零售商)
GOOGLE_MAPS_API_KEY=

# 展會與預約資訊(會寫進 outreach 信件)
TIHS_BOOTH="Clean + Contain 分區,攤位號碼待定"
CALENDLY_URL=https://calendly.com/your-account/tihs-2027
