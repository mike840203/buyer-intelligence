# 複製為 .env 後填入實際金鑰

# ── LLM 後端(擇一)──
# claude_code(預設):透過 Claude Code CLI 呼叫,走 Claude 訂閱額度,
#   免 API key 免儲值;需安裝 Claude Code(claude 指令)
# api:Anthropic SDK 直連,需組織有 API 額度(platform.claude.com 儲值)
LLM_BACKEND=claude_code

# claude 執行檔不在 PATH 時指定完整路徑
#CLAUDE_CLI=/Users/you/.local/bin/claude
# 訂閱方案沒有 Opus 時,把審稿模型降為 sonnet
#CLI_MODEL_TOP=sonnet

# LLM_BACKEND=api 時的認證(二選一):
#   方式 A:執行 `ant auth login` 登入帳號 → 免填,SDK 自動取用 profile
#   方式 B:填入 API key
ANTHROPIC_API_KEY=

# Apollo.io(L1 主力名單來源;免費 tier 可先驗證流程)
APOLLO_API_KEY=

# Hunter.io(L2 email 驗證;500 筆內有免費額度)
HUNTER_API_KEY=

# Google Maps Places API(L1 掃描目標城市咖啡店/廚具零售商)
GOOGLE_MAPS_API_KEY=

# 公司身分(寄件人、價值主張、展會/campaign、競品)不在這裡——
# 改 company/ankomn.toml;要換公司設 COMPANY_PROFILE=company/<name>.toml
#COMPANY_PROFILE=company/ankomn.toml

# ── L6 送後引擎(核准後的自動寄送)──
# eml(預設):乾跑,到期時輸出 outbox/*.eml 由人寄——排程/限流/狀態機照常運作
# gmail:Gmail API 自動寄出(需下方 OAuth 憑證;申請見 docs/gmail.md)
SENDING_BACKEND=eml

# 信末自動附 CAN-SPAM 合規 footer(寄件人地址 + reply UNSUBSCRIBE);0 = 只附簽名
ENABLE_COMPLIANCE_FOOTER=1

# 暖機:前 N 週每日上限壓低(防 Gmail 風控)。起算日留空 = 第一封實際寄出日
#WARMUP_START_DATE=2026-08-01
#WARMUP_WEEKS=2
#DAILY_LIMIT_WARMUP=2
#DAILY_LIMIT_NORMAL=5

# 寄信時段(buyer 當地時間)與同批錯開間隔(分鐘)
#SEND_WINDOW_START=09:30
#SEND_WINDOW_END=16:30
#INTERVAL_MIN_MINUTES=60
#INTERVAL_MAX_MINUTES=90

# SENDING_BACKEND=gmail 時必填(申請步驟見 docs/gmail.md)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
